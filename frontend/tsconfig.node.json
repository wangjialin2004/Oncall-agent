{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./node_modules/.tmp/tsconfig-node-output",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node", "vitest"]
  },
  "include": ["vite.config.ts"]
}
