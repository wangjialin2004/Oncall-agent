# Copy this file to .env and fill in local values. Do not commit .env.

# App
# APP_NAME=AIOps Assistant
# APP_VERSION=1.0.0
# DEBUG=false
# HOST=0.0.0.0
# PORT=9900

# LLM provider
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://dasuapi.com/v1
# LLM_API_KEY=your-llm-api-key-here
# LLM_MODEL=gpt-5.4
# LLM_TIMEOUT=60
# LLM_MAX_RETRIES=2
# LLM_RETRY_BASE_DELAY=0.5

# DashScope / embeddings
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
# DASHSCOPE_MODEL=
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# RAG
# RAG_TOP_K=3
# RAG_MODEL=gpt-5.4
# RAG_RETRIEVAL_MODE=dense
# RAG_DENSE_WEIGHT=0.7
# RAG_BM25_WEIGHT=0.3

# Agent harness
# HARNESS_ENABLED=false
# HARNESS_MAX_STEPS=6
# HARNESS_TOKEN_BUDGET=16000
# HARNESS_TIMEOUT_SECONDS=90
# HARNESS_MCP_ENABLED=false
# HARNESS_DELEGATION_ENABLED=true

# Logs and runtime limits
# LOG_MAX_LINES=20000
# LOG_TOKEN_BUDGET=12000
# LOG_CHUNK_SIZE=8000
# LOG_TOP_PATTERNS=30
# LOG_SUMMARY_MODEL=

# Milvus
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_TIMEOUT=10000

# MCP servers
# MCP_CLS_TRANSPORT=streamable-http
# MCP_CLS_URL=http://localhost:8003/mcp
# MCP_MONITOR_TRANSPORT=streamable-http
# MCP_MONITOR_URL=http://localhost:8004/mcp

# Prometheus / monitor
# PROMETHEUS_BASE_URL=http://127.0.0.1:9090
# PROMETHEUS_REQUEST_TIMEOUT=10
# MONITOR_TARGET_MODE=self
# LOG_PROVIDER=local

# Storage
# CHECKPOINT_DB_PATH=volumes/checkpoints.db
# MEMORY_DB_PATH=volumes/long_term_memory.db
# PROJECT_ID=super_biz_agent

# Auth
# AUTH_TOKEN_SECRET=replace-with-a-local-random-secret
